rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------------
    // PHASE 3: Primitive Definitions & Helpers
    // ---------------------------------------------------------
    
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function isStaff() { 
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return isSignedIn() && (role == 'admin' || role == 'lawyer' || role == 'researcher' || role == 'secretary' || role == 'secretariat' || role == 'accountant');
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // ENTITY VALIDATORS
    // ---------------------------------------------------------

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128
          && data.name is string && data.name.size() <= 200
          && data.role in ['admin', 'lawyer', 'researcher', 'secretary', 'secretariat', 'accountant', 'client']
          && (!('email' in data) || (data.email is string && data.email.size() <= 255))
          && (!('phone' in data) || (data.phone is string && data.phone.size() <= 20));
    }

    function isValidCase(data) {
      return data.id is string && data.id.size() <= 128
          && data.caseNumber is string && data.caseNumber.size() <= 50
          && data.caseName is string && data.caseName.size() <= 500
          && (!('status' in data) || (data.status is string && data.status.size() <= 50));
    }

    function isValidClient(data) {
      return data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 200;
    }

    function isValidEmployee(data) {
      return data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 200
          && data.username is string && data.username.size() <= 50;
    }

    // ---------------------------------------------------------
    // COLLECTION MATCHES
    // ---------------------------------------------------------

    // EMPLOYEES COLLECTION
    match /employees/{empId} {
       allow read, write: if isStaff();
    }

    // AUDIT LOGS
    match /auditlogs/{logId} {
       allow read: if isStaff();
       allow create: if isSignedIn();
    }

    // USERS COLLECTION
    match /users/{uid} {
      allow get: if isSignedIn();
      allow list: if isStaff();
      allow create: if isOwner(uid) && isValidUser(incoming());
      allow update: if (isOwner(uid) || isAdmin()) && isValidUser(incoming()) && (
        // Prevent self-privilege escalation
        (isOwner(uid) && !incoming().diff(existing()).affectedKeys().hasAny(['role'])) ||
        isAdmin()
      );
      
      match /preferences/{preferenceId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // CASES COLLECTION
    match /cases/{caseId} {
      allow read: if isStaff() || (isSignedIn() && existing().clientId == request.auth.uid);
      allow create: if isStaff() && isValidCase(incoming());
      allow update: if (isStaff() || isAdmin()) && isValidCase(incoming());
      allow delete: if isAdmin();
    }

    // CLIENTS COLLECTION
    match /clients/{clientId} {
       allow read: if isStaff() || isOwner(clientId);
       allow create: if isStaff() && isValidClient(incoming());
       allow update: if (isStaff() || isAdmin()) && isValidClient(incoming());
       allow delete: if isAdmin();
    }

    // TASKS COLLECTION
    match /tasks/{taskId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    // INVOICES COLLECTION
    match /invoices/{invoiceId} {
      allow read: if isStaff() || (isSignedIn() && existing().clientId == request.auth.uid);
      allow write: if isStaff();
    }

    // MESSAGES COLLECTION
    match /messages/{messageId} {
      allow read: if isStaff() || (isSignedIn() && (existing().sender == request.auth.uid || existing().recipient == request.auth.uid));
      allow create: if isSignedIn();
    }

    // HEARINGS COLLECTION
    match /hearings/{hearingId} {
      allow read: if isStaff() || (isSignedIn() && existing().clientId == request.auth.uid);
      allow write: if isStaff();
    }

    // SYSTEM ERRORS COLLECTION (Publicly appendable for robustness)
    match /system_errors/{errorId} {
      allow create: if true; 
      allow read: if isStaff();
    }
  }
}
