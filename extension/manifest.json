{
  "manifest_version": 3,
  "name": "منصة العدالة - مزامنة ناجز",
  "version": "2.0",
  "description": "مزامنة تلقائية لبيانات ناجز مع منصة العدالة الذكية",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "*://*.najiz.sa/*",
    "*://*.adalah.law/*",
    "*://*.adalah.cloud/*",
    "http://localhost:*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.najiz.sa/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
