{
  "manifest_version": 3,
  "name": "منصة العدالة — مزامنة ناجز",
  "version": "3.0",
  "description": "سحب بيانات القضايا من ناجز ومزامنتها مع منصة العدالة",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.najiz.sa/*",
    "https://najiz.sa/*",
    "https://*.najiz.sa/*",
    "https://aladala-platform-rnuz.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.najiz.sa/*",
        "https://najiz.sa/*",
        "https://*.najiz.sa/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "العدالة — سحب ناجز"
  },
  "background": {
    "service_worker": "background.js"
  }
}
