{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the platform (Lawyer or Client).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["partner", "consultant", "associate", "trainee", "accountant", "secretary", "client"] },
        "phone": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "officeLogo": { "type": "string" }
      },
      "required": ["uid", "name", "role"]
    },
    "Case": {
      "title": "Case",
      "description": "Represents a legal case.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "caseNumber": { "type": "string" },
        "caseName": { "type": "string" },
        "category": { "type": "string" },
        "stage": { "type": "string" },
        "status": { "type": "string" },
        "clientName": { "type": "string" },
        "clientId": { "type": "string" },
        "opponentName": { "type": "string" },
        "courtName": { "type": "string" },
        "summary": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string" },
        "archived": { "type": "boolean" }
      },
      "required": ["id", "caseNumber", "caseName"]
    },
    "ArchiveItem": {
      "title": "ArchiveItem",
      "description": "Electronic archiving for each case.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "caseId": { "type": "string" },
        "type": { "type": "string", "enum": ["pleading", "document", "judgment", "execution_decision", "other"] },
        "title": { "type": "string" },
        "fileUrl": { "type": "string" },
        "uploadedBy": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "caseId", "type", "title", "fileUrl"]
    },
    "TimeLog": {
      "title": "TimeLog",
      "description": "Work hours log for cases.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "lawyerId": { "type": "string" },
        "caseId": { "type": "string" },
        "clientId": { "type": "string" },
        "duration": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "isBilled": { "type": "boolean" }
      },
      "required": ["id", "lawyerId", "duration", "date"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "ZATCA compliant tax invoice.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "clientId": { "type": "string" },
        "amount": { "type": "number" },
        "vatAmount": { "type": "number" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "issueDate": { "type": "string" },
        "qrCodeData": { "type": "string" },
        "zatcaPhase": { "type": "number" }
      },
      "required": ["id", "totalAmount", "clientId"]
    },
    "Voucher": {
      "title": "Voucher",
      "description": "Receipt or payment voucher.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["receipt", "payment"] },
        "date": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "amount", "type", "date"]
    },
    "LibraryItem": {
      "title": "LibraryItem",
      "description": "Saudi regulations and laws.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "content": { "type": "string" },
        "lastUpdated": { "type": "string" }
      },
      "required": ["id", "title", "content"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Represents an employee or lawyer in the office.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "nationality": { "type": "string" },
        "nationalId": { "type": "string" },
        "phone": { "type": "string" },
        "jobTitle": { "type": "string" },
        "manager": { "type": "string" },
        "qualification": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "email": { "type": "string" },
        "branch": { "type": "string" },
        "notes": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "assignedCases": { "type": "array" },
        "assignedClients": { "type": "array" },
        "permissions": { "type": "array" },
        "sidebarConfig": { "type": "array" },
        "najizApiKey": { "type": "string" },
        "portalLink": { "type": "string" },
        "customLoginToken": { "type": "string" }
      },
      "required": ["id", "name", "username"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "System activity logs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["id", "timestamp", "action"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "Profiles." },
    "/employees/{empId}": { "schema": "Employee", "description": "Employee accounts." },
    "/auditlogs/{logId}": { "schema": "AuditLog", "description": "Activity logs." },
    "/cases/{caseId}": { "schema": "Case", "description": "Legal cases." },
    "/archive/{archiveId}": { "schema": "ArchiveItem", "description": "Electronic archive items." },
    "/timelogs/{logId}": { "schema": "TimeLog", "description": "Time tracking." },
    "/invoices/{invoiceId}": { "schema": "Invoice", "description": "Tax invoices." },
    "/vouchers/{voucherId}": { "schema": "Voucher", "description": "Financial vouchers." },
    "/library/{itemId}": { "schema": "LibraryItem", "description": "Legal library." }
  }
}
