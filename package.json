{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "check-types": "tsc --noEmit",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:client": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "validate": "tsc --noEmit",
    "lint": "tsc --noEmit --skipLibCheck",
    "lint:css": "stylelint 'src/**/*.css'",
    "test:install": "npx playwright install --with-deps chromium",
    "test:visual": "npx playwright test src/tests/visual.spec.ts",

    "start": "node dist/server.cjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
